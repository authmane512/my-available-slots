CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
CAL_API_VERSION=2024-08-13

# Comma-separated list of event types: slug:title:duration
# Example: 30min:30 Minute Meeting:30,60min:60 Minute Meeting:60
CAL_EVENT_TYPES=30min:30 Minute Meeting:30,60min:60 Minute Meeting:60

# Your Cal.com username
CAL_USERNAME=your-username

# Frontend: API base URL (leave empty for local dev with Vite proxy)
VITE_API_URL=
